<title>Frontend Interview Q&A — 3-4 Years Experience</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Syne:wght@400;600;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0f14;
    --surface: #13161e;
    --surface2: #1a1e2a;
    --border: #252a38;
    --accent: #4f8ef7;
    --accent2: #f7934f;
    --accent3: #4ff7a0;
    --accent4: #f74f8e;
    --text: #e2e6f0;
    --muted: #7a8099;
    --code-bg: #0a0c11;
    --tag-js: rgba(79,142,247,0.15);
    --tag-react: rgba(79,247,160,0.15);
    --tag-ng: rgba(247,75,142,0.12);
    --tag-perf: rgba(247,147,79,0.15);
    --tag-auth: rgba(147,79,247,0.15);
    --tag-bundle: rgba(79,220,247,0.15);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
    font-size: 15px;
  }

  /* ── HERO ── */
  .hero {
    background: linear-gradient(135deg, #0d0f14 0%, #12182e 50%, #0d0f14 100%);
    border-bottom: 1px solid var(--border);
    padding: 60px 24px 48px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(79,142,247,0.08), transparent);
  }
  .hero h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 800;
    background: linear-gradient(135deg, #4f8ef7, #4ff7a0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    position: relative;
    line-height: 1.2;
    margin-bottom: 12px;
  }
  .hero p {
    color: var(--muted);
    font-size: 14px;
    position: relative;
    max-width: 500px;
    margin: 0 auto 24px;
  }
  .badges { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; position: relative; }
  .badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    padding: 4px 12px;
    border-radius: 20px;
    border: 1px solid;
    letter-spacing: 0.05em;
  }
  .badge-js { background: var(--tag-js); border-color: rgba(79,142,247,0.4); color: #7eb4ff; }
  .badge-react { background: var(--tag-react); border-color: rgba(79,247,160,0.4); color: #4ff7a0; }
  .badge-ng { background: var(--tag-ng); border-color: rgba(247,75,142,0.4); color: #f74fa0; }
  .badge-perf { background: var(--tag-perf); border-color: rgba(247,147,79,0.4); color: #f7934f; }
  .badge-auth { background: var(--tag-auth); border-color: rgba(147,79,247,0.4); color: #b07aff; }
  .badge-bundle { background: var(--tag-bundle); border-color: rgba(79,220,247,0.4); color: #4feaf7; }

  /* ── LAYOUT ── */
  .container { max-width: 900px; margin: 0 auto; padding: 0 16px 80px; }

  /* ── NAV TABS ── */
  .nav-wrap {
    position: sticky; top: 0; z-index: 100;
    background: rgba(13,15,20,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 16px;
  }
  .nav-tabs {
    display: flex; gap: 0; overflow-x: auto;
    max-width: 900px; margin: 0 auto;
    scrollbar-width: none;
  }
  .nav-tabs::-webkit-scrollbar { display: none; }
  .nav-tab {
    flex-shrink: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    padding: 14px 16px;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    white-space: nowrap;
    background: none; border-top: none; border-left: none; border-right: none;
  }
  .nav-tab:hover { color: var(--text); }
  .nav-tab.active { color: var(--accent); border-bottom-color: var(--accent); }

  /* ── SECTION ── */
  .section { margin-top: 48px; }
  .section-header {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .section-icon {
    width: 36px; height: 36px;
    border-radius: 8px;
    display: grid; place-items: center;
    font-size: 18px;
    flex-shrink: 0;
  }
  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
  }
  .section-count {
    margin-left: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    background: var(--surface2);
    padding: 3px 10px;
    border-radius: 20px;
    flex-shrink: 0;
  }

  /* ── Q&A CARD ── */
  .qa-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    margin-bottom: 12px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .qa-card:hover { border-color: rgba(79,142,247,0.3); }
  .qa-card.open { border-color: rgba(79,142,247,0.5); }

  .qa-question {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px 18px;
    cursor: pointer;
    user-select: none;
  }
  .qa-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    min-width: 28px;
    padding-top: 2px;
  }
  .qa-q-text {
    flex: 1;
    font-weight: 500;
    font-size: 14px;
    color: var(--text);
    line-height: 1.5;
  }
  .qa-arrow {
    color: var(--muted);
    font-size: 12px;
    transition: transform 0.25s;
    padding-top: 3px;
    flex-shrink: 0;
  }
  .qa-card.open .qa-arrow { transform: rotate(180deg); color: var(--accent); }

  .qa-answer {
    display: none;
    padding: 0 18px 18px 58px;
  }
  .qa-card.open .qa-answer { display: block; }

  .qa-answer p { color: #c5cce0; font-size: 14px; margin-bottom: 12px; line-height: 1.75; }
  .qa-answer p:last-child { margin-bottom: 0; }

  .qa-answer ul, .qa-answer ol {
    color: #c5cce0;
    font-size: 14px;
    padding-left: 20px;
    margin-bottom: 12px;
  }
  .qa-answer li { margin-bottom: 6px; line-height: 1.65; }

  .qa-answer code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    background: var(--code-bg);
    border: 1px solid var(--border);
    padding: 2px 7px;
    border-radius: 4px;
    color: #a8d8ff;
  }

  .qa-answer pre {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px;
    overflow-x: auto;
    margin: 12px 0;
    color: #a8d8ff;
    line-height: 1.6;
  }

  .tip {
    background: rgba(79,247,160,0.06);
    border: 1px solid rgba(79,247,160,0.2);
    border-left: 3px solid var(--accent3);
    border-radius: 6px;
    padding: 10px 14px;
    font-size: 13px;
    color: #9fffd4;
    margin-top: 12px;
  }
  .tip strong { color: var(--accent3); }

  .warn {
    background: rgba(247,147,79,0.06);
    border: 1px solid rgba(247,147,79,0.2);
    border-left: 3px solid var(--accent2);
    border-radius: 6px;
    padding: 10px 14px;
    font-size: 13px;
    color: #ffc099;
    margin-top: 12px;
  }

  /* table */
  .qa-answer table { width: 100%; border-collapse: collapse; font-size: 13px; margin: 12px 0; }
  .qa-answer th { background: var(--surface2); color: var(--accent); font-family: 'JetBrains Mono', monospace; font-size: 11px; padding: 8px 12px; text-align: left; border: 1px solid var(--border); }
  .qa-answer td { padding: 8px 12px; border: 1px solid var(--border); color: #c5cce0; vertical-align: top; }
  .qa-answer tr:nth-child(even) td { background: rgba(255,255,255,0.02); }

  strong { color: #e8ecf8; }
  em { color: var(--accent2); font-style: normal; font-weight: 500; }

  /* ── BACK TO TOP ── */
  .back-top {
    position: fixed; bottom: 24px; right: 20px;
    background: var(--accent); color: #fff;
    border: none; border-radius: 50%;
    width: 40px; height: 40px;
    font-size: 18px; cursor: pointer;
    box-shadow: 0 4px 20px rgba(79,142,247,0.4);
    display: grid; place-items: center;
    transition: transform 0.2s;
    z-index: 200;
  }
  .back-top:hover { transform: translateY(-3px); }

  @media (max-width: 600px) {
    .qa-answer { padding-left: 18px; }
    .qa-num { display: none; }
  }
</style>
</head>
